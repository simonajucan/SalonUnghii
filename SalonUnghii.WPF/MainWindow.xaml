<Window x:Class="SalonUnghii.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="✨ Salon Unghii - Gestiune Programări"
        Width="900"
        Height="600"
        WindowState="Maximized"
        WindowStyle="ThreeDBorderWindow"
        Background="#F2D7D5">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F2D7D5" Offset="0"/>
                <GradientStop Color="#F9C6C6" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="420">

            <Border Height="4"
                    CornerRadius="2"
                    Margin="0,0,0,30">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#E8A598" Offset="0"/>
                        <GradientStop Color="#C96A6A" Offset="0.5"/>
                        <GradientStop Color="#E8A598" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Label Content="✨ Salon Unghii Elite"
                   HorizontalAlignment="Center"
                   HorizontalContentAlignment="Center"
                   FontFamily="Georgia"
                   FontSize="36"
                   FontWeight="Bold"
                   FontStyle="Italic"
                   Foreground="#7A2E2E"
                   Padding="0,0,0,8"/>
>
            <Label Content="Frumusețea începe cu detaliile mici"
                   HorizontalAlignment="Center"
                   HorizontalContentAlignment="Center"
                   FontFamily="Trebuchet MS"
                   FontSize="16"
                   FontWeight="Normal"
                   FontStyle="Italic"
                   Foreground="#C96A6A"
                   Padding="0,0,0,6"/>


            <Label Content="📞 Program: Luni–Sâmbătă, 09:00 – 19:00"
                   HorizontalAlignment="Center"
                   HorizontalContentAlignment="Center"
                   FontFamily="Segoe UI"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="#8B5C5C"
                   Padding="0,0,0,30"/>


            <Border Height="4"
                    CornerRadius="2">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#E8A598" Offset="0"/>
                        <GradientStop Color="#C96A6A" Offset="0.5"/>
                        <GradientStop Color="#E8A598" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

        </StackPanel>

    </Grid>
</Window>
